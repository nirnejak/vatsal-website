{
  "name": "vatsal-website",
  "description": "Personal website of Vatsal Dhameliya, a machine learning scientist.",
  "version": "1.0.0",
  "author": "Jitendra Nirnejak <jeetnirnejak@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "tsc --pretty --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.7",
    "akar-icons": "^1.9.31",
    "dotenv": "^17.4.2",
    "motion": "^12.40.0",
    "next": "^16.2.7",
    "next-view-transitions": "^0.3.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": "biome check --fix --no-errors-on-unmatched"
  },
  "volta": {
    "node": "24.12.0"
  },
  "keywords": [
    "nextjs",
    "react",
    "typescript",
    "biome",
    "precommit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nirnejak/vatsal-website"
  },
  "bugs": {
    "url": "https://github.com/nirnejak/vatsal-website/issues"
  }
